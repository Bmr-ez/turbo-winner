<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.antigravity.gemini.assistant" ExtensionBundleVersion="1.0.0"
	ExtensionBundleName="Gemini AE Assistant" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<ExtensionList>
		<Extension Id="com.antigravity.gemini.assistant.panel" Version="1.0.0" />
	</ExtensionList>
	<ExecutionEnvironment>
		<HostList>
			<Host Name="AEFT" Version="[13.0,99.9]" />
		</HostList>
		<LocaleList>
			<Locale Code="All" />
		</LocaleList>
		<RequiredRuntimeList>
			<RequiredRuntime Name="CSXS" Version="7.0" />
		</RequiredRuntimeList>
	</ExecutionEnvironment>
	<DispatchInfoList>
		<Extension Id="com.antigravity.gemini.assistant.panel">
			<DispatchInfo>
				<Resources>
					<MainPath>./client/index.html</MainPath>
					<ScriptPath>./host/script.jsx</ScriptPath>
					<CEFCommandLine>
						<Parameter>--enable-nodejs</Parameter>
						<Parameter>--mixed-context</Parameter>
					</CEFCommandLine>
				</Resources>
				<Lifecycle>
					<AutoVisible>true</AutoVisible>
				</Lifecycle>
				<UI>
					<Type>Panel</Type>
					<Menu>Gemini AE Assistant</Menu>
					<Geometry>
						<Size>
							<Width>350</Width>
							<Height>600</Height>
						</Size>
						<MinSize>
							<Width>300</Width>
							<Height>400</Height>
						</MinSize>
					</Geometry>
				</UI>
			</DispatchInfo>
		</Extension>
	</DispatchInfoList>
</ExtensionManifest>
